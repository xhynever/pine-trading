//@version=5
strategy("4H Vegas Channel Strategy - LONG ONLY v2.0",
         overlay=true,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=20)

// ============================================================================
// 第一部分: 内联库函数
// ============================================================================

// 计算5条EMA指标
f_calculate_emas(int len12, int len144, int len156, int len565, int len676) =>
    [ta.ema(close, len12), ta.ema(close, len144), ta.ema(close, len156), ta.ema(close, len565), ta.ema(close, len676)]

// 检测空头趋势: ema12 < min(ema144, ema156) < min(ema565, ema676)
f_is_downtrend(float ema12, float ema144, float ema156, float ema565, float ema676) =>
    ema12 < math.min(ema144, ema156) and math.min(ema144, ema156) < math.min(ema565, ema676)

// 检测多头趋势: ema12 > max(ema144, ema156) > max(ema565, ema676)
f_is_uptrend(float ema12, float ema144, float ema156, float ema565, float ema676) =>
    ema12 > math.max(ema144, ema156) and math.max(ema144, ema156) > math.max(ema565, ema676)

// 计算真实波幅指标 (ATR)
f_calculate_volatility(int period) =>
    ta.atr(period)

// 记录价格到数组
f_record_price(float price, float threshold, array<float> high_arr, array<float> low_arr, int capacity) =>
    if price > threshold
        array.push(high_arr, price)
    else
        array.push(low_arr, price)

    if array.size(high_arr) > capacity
        array.shift(high_arr)
    if array.size(low_arr) > capacity
        array.shift(low_arr)

// 检查价格是否接近指定EMA (容差范围)
f_check_price_near_ema(float price, float ema, float offset_percent) =>
    price >= ema * (1 - offset_percent / 100) and price <= ema * (1 + offset_percent / 100)

// ============================================================================
// 第二部分: 参数定义
// ============================================================================

// 趋势与波动率参数
ATR_PERIOD = input(14, "ATR Calculation Period", group="Trend Parameters")

// 开仓参数
ENTRY_QTY = input(0.1, "Entry Position Size", group="Entry Parameters")
ENTRY_OFFSET_PERCENT = input(3.0, "Entry Price Offset (%)", group="Entry Parameters")
PRICE_ARRAY_THRESHOLD = input(8, "Price Collection Threshold (bars)", group="Entry Parameters")
MAX_POSITION_SIZE = input(2, "Max Position Batches", group="Entry Parameters")

// 止损止盈参数
SL_ATR_MULTIPLE = input(2.0, "Stop Loss (ATR Multiple)", group="Risk Management")
TP1_PERCENT = input(10.0, "Take Profit 1 (%)", group="Risk Management")
TP2_PERCENT = input(15.0, "Take Profit 2 (%)", group="Risk Management")
TP3_PERCENT = input(25.0, "Take Profit 3 (%)", group="Risk Management")

// 高级参数
QUEUE_CAPACITY = input(48, "Array Queue Capacity", group="Advanced")

// ============================================================================
// 第三部分: 指标计算
// ============================================================================

// 日线EMA (参考用)
ema12_d = request.security(syminfo.tickerid, "D", ta.ema(close, 12))
ema144_d = request.security(syminfo.tickerid, "D", ta.ema(close, 144))
ema156_d = request.security(syminfo.tickerid, "D", ta.ema(close, 156))
ema565_d = request.security(syminfo.tickerid, "D", ta.ema(close, 565))
ema676_d = request.security(syminfo.tickerid, "D", ta.ema(close, 676))

// 4H主EMA (5条)
[ema12, ema144, ema156, ema565, ema676] = f_calculate_emas(12, 144, 156, 565, 676)

// 趋势判断
downtrend = f_is_downtrend(ema12, ema144, ema156, ema565, ema676)
uptrend = f_is_uptrend(ema12, ema144, ema156, ema565, ema676)

// 真实波幅计算
atr_value = f_calculate_volatility(ATR_PERIOD)

// EMA12与EMA144的交叉
ema12_crossover_ema144 = ta.crossover(ema12, ema144)

// ============================================================================
// 第四部分: 状态变量
// ============================================================================

// 趋势状态
var bool downtrend_confirmed = false      // 空头趋势已确认
var bool entry_signal_active = false      // 开仓信号激活

// 分批头寸管理
var array<float> batch_entry_prices = array.new<float>()  // 各批入场价
var array<float> batch_sl_prices = array.new<float>()     // 各批止损价
var array<string> batch_ids = array.new<string>()         // 各批订单ID
var array<int> batch_bars_since_entry = array.new<int>()  // 各批开仓后的K线数

// 价格记录数组
var array<float> highprice = array.new<float>()  // 高于EMA12的收盘价
var array<float> lowprice = array.new<float>()   // 低于EMA12的收盘价

// 信号标记
var bool entry_signal = false
var bool crossover_signal = false

// ============================================================================
// 第五部分: 交易逻辑 - 简化版
// ============================================================================

// 步骤1: 检测趋势变化
if downtrend and not downtrend_confirmed
    downtrend_confirmed := true
    entry_signal_active := true

if uptrend
    downtrend_confirmed := false
    entry_signal_active := false

// 步骤2: 在空头趋势中，检测EMA12上穿EMA144作为开仓触发信号
if downtrend_confirmed and ema12_crossover_ema144
    crossover_signal := true
else
    crossover_signal := false

// 步骤3: 当空头趋势确认且价格合适时开仓
// 条件: 空头趋势 + (EMA12上穿过 或 价格接近EMA12/EMA144) + 未达到最大头寸
if downtrend_confirmed and entry_signal_active and array.size(batch_ids) < MAX_POSITION_SIZE
    entry_signal := false

    // 第一批: 当价格接近或低于EMA12时开仓
    if array.size(batch_ids) == 0
        price_near_ema12 = f_check_price_near_ema(close, ema12, ENTRY_OFFSET_PERCENT)
        if price_near_ema12 or ema12_crossover_ema144
            entry_price = close
            batch_id = "Long_1"
            strategy.entry(batch_id, strategy.long, qty=ENTRY_QTY)
            entry_signal := true

            // 初始止损 = 入场价 - 2*ATR
            sl_price = entry_price - (atr_value * SL_ATR_MULTIPLE)

            array.push(batch_entry_prices, entry_price)
            array.push(batch_sl_prices, sl_price)
            array.push(batch_ids, batch_id)
            array.push(batch_bars_since_entry, 0)

            array.clear(highprice)
            array.clear(lowprice)

    // 第二批: 当价格再次接近EMA144时加仓
    else if array.size(batch_ids) == 1
        price_near_ema144 = f_check_price_near_ema(close, ema144, ENTRY_OFFSET_PERCENT)
        if price_near_ema144
            entry_price = close
            batch_id = "Long_2"
            strategy.entry(batch_id, strategy.long, qty=ENTRY_QTY)
            entry_signal := true

            sl_price = entry_price - (atr_value * SL_ATR_MULTIPLE)

            array.push(batch_entry_prices, entry_price)
            array.push(batch_sl_prices, sl_price)
            array.push(batch_ids, batch_id)
            array.push(batch_bars_since_entry, 0)

// ============================================================================
// 第六部分: 持仓管理 - 动态止损
// ============================================================================

if strategy.position_size > 0 and array.size(batch_ids) > 0
    // 记录价格 (根据EMA12分类)
    f_record_price(close, ema12, highprice, lowprice, QUEUE_CAPACITY)

    // 为每个已开仓的批次更新计数和止损
    for i = 0 to array.size(batch_ids) - 1
        batch_id_val = array.get(batch_ids, i)
        entry_price = array.get(batch_entry_prices, i)
        current_sl = array.get(batch_sl_prices, i)
        bars_count = array.get(batch_bars_since_entry, i) + 1
        array.set(batch_bars_since_entry, i, bars_count)

        // 条件1: 硬止损 - 开单后跌破成本价5%直接平仓
        hardstop_price = entry_price * (1 - 0.05)
        if close < hardstop_price
            strategy.close(batch_id_val, comment="Hard Stop Loss 5%")
            array.remove(batch_entry_prices, i)
            array.remove(batch_sl_prices, i)
            array.remove(batch_ids, i)
            array.remove(batch_bars_since_entry, i)
            break

        // 条件2: 第8根K线时，检查高于EMA12的收盘价数量
        if bars_count == 8
            high_count = array.size(highprice)
            // 如果高于EMA12的K线数少于4根，则在成本价平仓
            if high_count < 4
                strategy.close(batch_id_val, comment="Cost Price Close (High < 4)")
                array.remove(batch_entry_prices, i)
                array.remove(batch_sl_prices, i)
                array.remove(batch_ids, i)
                array.remove(batch_bars_since_entry, i)
                break

        // 条件3: 8根K线后，动态调整止损
        if bars_count > 8
            new_sl = entry_price - (atr_value * SL_ATR_MULTIPLE)
            // 止损只能向上调整，不能向下
            if new_sl > current_sl
                array.set(batch_sl_prices, i, new_sl)
                strategy.exit("SL_" + batch_id_val, batch_id_val, stop=new_sl)
            else
                strategy.exit("SL_" + batch_id_val, batch_id_val, stop=current_sl)
        else
            // 8根K线内保持固定止损（成本价-5%）
            strategy.exit("SL_" + batch_id_val, batch_id_val, stop=hardstop_price)

// 全部头寸平仓时，重置状态
if strategy.position_size == 0 and array.size(batch_ids) > 0
    array.clear(batch_entry_prices)
    array.clear(batch_sl_prices)
    array.clear(batch_ids)
    array.clear(batch_bars_since_entry)
    array.clear(highprice)
    array.clear(lowprice)

    entry_signal_active := false
    downtrend_confirmed := false

// ============================================================================
// 第七部分: 止盈执行
// ============================================================================

if array.size(batch_entry_prices) > 0
    for i = 0 to array.size(batch_entry_prices) - 1
        entry_price = array.get(batch_entry_prices, i)
        batch_id_val = array.get(batch_ids, i)

        // 三层止盈: 25%止盈100% > 15%止盈 > 10%止盈
        if close > entry_price * (1 + TP3_PERCENT / 100)
            strategy.close(batch_id_val, comment="TP3 100% @" + str.tostring(TP3_PERCENT) + "%")
            array.remove(batch_entry_prices, i)
            array.remove(batch_sl_prices, i)
            array.remove(batch_ids, i)
            array.remove(batch_bars_since_entry, i)
            break
        else if close > entry_price * (1 + TP2_PERCENT / 100)
            strategy.close(batch_id_val, comment="TP2 25% @" + str.tostring(TP2_PERCENT) + "%")
            array.remove(batch_entry_prices, i)
            array.remove(batch_sl_prices, i)
            array.remove(batch_ids, i)
            array.remove(batch_bars_since_entry, i)
            break
        else if close > entry_price * (1 + TP1_PERCENT / 100)
            strategy.close(batch_id_val, comment="TP1 50% @" + str.tostring(TP1_PERCENT) + "%")
            array.remove(batch_entry_prices, i)
            array.remove(batch_sl_prices, i)
            array.remove(batch_ids, i)
            array.remove(batch_bars_since_entry, i)
            break

// ============================================================================
// 第八部分: 可视化
// ============================================================================

// EMA绘制
plot(ema12, color=color.blue, linewidth=2, title="EMA12")
plot(ema144, color=color.red, linewidth=2, title="EMA144")
plot(ema156, color=color.orange, linewidth=1, title="EMA156")
plot(ema565, color=color.purple, linewidth=1, title="EMA565")
plot(ema676, color=color.teal, linewidth=1, title="EMA676")

// 信号标记
// EMA12上穿EMA144的标记
plotshape(crossover_signal, location=location.abovebar,
          color=color.orange, size=size.small, text="↑", title="Crossover Signal")

// 开多单时的标记
plotshape(entry_signal, location=location.belowbar,
          color=color.green, size=size.small, text="BUY", title="Entry Signal")

// 趋势背景
bgcolor(downtrend ? color.new(color.red, 90) : na, title="Downtrend")
bgcolor(uptrend ? color.new(color.green, 90) : na, title="Uptrend")
